$(OBJDIR)$(DLL_PREFIX)simple_plugin$(DLL_SUFFIX): simple_plugin.cpp
	$(APP_CXX) $(RPC_PLUGIN_CXXFLAGS) $(DLL_CXXFLAGS) $(COMP_EXE)$@ $< $(APP_LDFLAGS) $(DLL_LDFLAGS) $(APP_LIBS)
	# Copy test plugin to the pind plugin directory
	$(CP) $(OBJDIR)$(DLL_PREFIX)simple_plugin$(DLL_SUFFIX) $(PIN_ROOT)/$(TARGET)/pinrt/bin/plugins/


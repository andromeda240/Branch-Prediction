###### Place all generic definitions here ######

# This defines tests which run tools of the same name.  This is simply for convenience to avoid
# defining the test name twice (once in TOOL_ROOTS and again in TEST_ROOTS).
# Tests defined here should not be defined in TOOL_ROOTS and TEST_ROOTS.
TEST_TOOL_ROOTS :=

# This defines the tests to be run that were not already defined in TEST_TOOL_ROOTS.
TEST_ROOTS := multiple_json_rpc_plugins override_pin_json_config

# This defines the tools which will be run during the the tests, and were not already defined in
# TEST_TOOL_ROOTS.
TOOL_ROOTS := inscount0

# This defines the static analysis tools which will be run during the the tests. They should not
# be defined in TEST_TOOL_ROOTS. If a test with the same name exists, it should be defined in
# TEST_ROOTS.
# Note: Static analysis tools are in fact executables linked with the Pin Static Analysis Library.
# This library provides a subset of the Pin APIs which allows the tool to perform static analysis
# of an application or dll. Pin itself is not used when this tool runs.
SA_TOOL_ROOTS :=

# This defines all the applications that will be run during the tests.
APP_ROOTS :=

# This defines any additional object files that need to be compiled.
OBJECT_ROOTS :=

# This defines any additional dlls (shared objects), other than the pintools, that need to be compiled.
DLL_ROOTS := simple_plugin

# This defines any static libraries (archives), that need to be built.
LIB_ROOTS :=

###### Place architecture-specific definitions here ######

# Place ia32-specific definitions here if they apply to all supported operating systems.
ifeq ($(TARGET),ia32)
    TEST_TOOL_ROOTS +=
    TEST_ROOTS +=
    TOOL_ROOTS +=
    SA_TOOL_ROOTS +=
    APP_ROOTS +=
    OBJECT_ROOTS +=
    DLL_ROOTS +=
    LIB_ROOTS +=
endif

# Place intel64-specific definitions here if they apply to all supported operating systems.
ifeq ($(TARGET),intel64)
    TEST_TOOL_ROOTS +=
    TEST_ROOTS +=
    TOOL_ROOTS +=
    SA_TOOL_ROOTS +=
    APP_ROOTS +=
    OBJECT_ROOTS +=
    DLL_ROOTS +=
    LIB_ROOTS +=
endif

###### Place OS-specific definitions here ######

# Linux
ifeq ($(TARGET_OS),linux)
    TEST_TOOL_ROOTS +=
    TEST_ROOTS += rsc_message_counter_fork_probe rsc_message_counter_fork_jit \
                  rsc_message_counter_fork_probe_auth rsc_message_counter_fork_jit_auth
    TOOL_ROOTS += probe_tool
    SA_TOOL_ROOTS +=
    APP_ROOTS += fork_app
    OBJECT_ROOTS +=
    DLL_ROOTS +=
    LIB_ROOTS +=
    ifeq ($(TARGET),ia32)
        TEST_TOOL_ROOTS +=
        TEST_ROOTS +=
        TOOL_ROOTS +=
        SA_TOOL_ROOTS +=
        APP_ROOTS +=
        OBJECT_ROOTS +=
        DLL_ROOTS +=
        LIB_ROOTS +=
    endif
    ifeq ($(TARGET),intel64)
        TEST_TOOL_ROOTS +=
        TEST_ROOTS +=
        TOOL_ROOTS +=
        SA_TOOL_ROOTS +=
        APP_ROOTS +=
        OBJECT_ROOTS +=
        DLL_ROOTS +=
        LIB_ROOTS +=
    endif
endif

# Windows
ifeq ($(TARGET_OS),windows)
    TEST_TOOL_ROOTS +=
    TEST_ROOTS +=
    TOOL_ROOTS +=
    SA_TOOL_ROOTS +=
    APP_ROOTS +=
    OBJECT_ROOTS +=
    DLL_ROOTS +=
    LIB_ROOTS +=
    ifeq ($(TARGET),ia32)
        TEST_TOOL_ROOTS +=
        TEST_ROOTS +=
        TOOL_ROOTS +=
        SA_TOOL_ROOTS +=
        APP_ROOTS +=
        OBJECT_ROOTS +=
        DLL_ROOTS +=
        LIB_ROOTS +=
    endif
    ifeq ($(TARGET),intel64)
        TEST_TOOL_ROOTS +=
        TEST_ROOTS +=
        TOOL_ROOTS +=
        SA_TOOL_ROOTS +=
        APP_ROOTS +=
        OBJECT_ROOTS +=
        DLL_ROOTS +=
        LIB_ROOTS +=
    endif
endif

###### Handle exceptions here (OS/arch related) ######

# Old GCC versions can't compile rscproto.h
ifeq ($(TARGET_OS),linux)
	GCC_VERSION_LE_4_8_5 := $(shell $(TOOLS_ROOT)/Utils/testToolVersion $(APP_CXXPATH) le 4.8.5)
	ifeq ($(GCC_VERSION_LE_4_8_5),1)
		TEST_ROOTS := $(filter-out multiple_json_rpc_plugins override_pin_json_config, $(TEST_ROOTS))
		DLL_ROOTS := $(filter-out simple_plugin, $(DLL_ROOTS))
	endif
endif

# If some tests need to be disabled because of unsupported features on OS/arch, do this here

# This defines the full list of tests prior to applying any bug related filters.
# It is being used to generate a report about filtered tests.
RUNNABLE_TESTS := $(TEST_TOOL_ROOTS) $(TEST_ROOTS)

###### Handle exceptions here (bugs related) ######

# If some tests need to be disabled because of known failures, do this here

###### Define the serial subset ######

# Defines which tests need to be run serially as may cause issues when running in parallel 
SERIAL_SUBSET := 

###### Define the sanity subset ######

# This defines the list of tests that should run in sanity. It should include all the tests listed in
# TEST_TOOL_ROOTS and TEST_ROOTS excluding only unstable tests.
SANITY_SUBSET := $(TEST_TOOL_ROOTS) $(TEST_ROOTS)


##############################################################
#
# Test recipes
#
##############################################################

###### Finalize sanity here ######

# This section contains recipes for tests other than the default.
# See makefile.default.rules for the default test rules.
# All tests in this section should adhere to the naming convention: <testname>.test

# Tests rsc message counter issue that we saw as a result of multiple forks being done by the same process causing 
# the RSC message counter of the RSC server to drift away from the RSC message counter of the RSC client which results 
# (after many forks) in failing to send a RSC message from one of RSC clients to the main process RSC server 
# (either from main RSC client or from the RSC client of one of the forked children)
rsc_message_counter_fork_probe.test: $(OBJDIR)probe_tool$(PINTOOL_SUFFIX) $(OBJDIR)fork_app$(EXE_SUFFIX)
	$(PIN) -probe -t $(OBJDIR)probe_tool$(PINTOOL_SUFFIX) -- $(OBJDIR)fork_app$(EXE_SUFFIX)

# Same comment as in rsc_message_counter_fork_probe.test
rsc_message_counter_fork_jit.test: $(OBJDIR)probe_tool$(PINTOOL_SUFFIX) $(OBJDIR)fork_app$(EXE_SUFFIX)
	$(PIN) -- $(OBJDIR)fork_app$(EXE_SUFFIX)

rsc_message_counter_fork_probe.test_auth: $(OBJDIR)probe_tool$(PINTOOL_SUFFIX) $(OBJDIR)fork_app$(EXE_SUFFIX)
	$(PIN) -xyzzy -enable_rpc_authentication -probe -t $(OBJDIR)probe_tool$(PINTOOL_SUFFIX) -- $(OBJDIR)fork_app$(EXE_SUFFIX)

# Same comment as in rsc_message_counter_fork_probe.test
rsc_message_counter_fork_jit_auth.test:  $(OBJDIR)probe_tool$(PINTOOL_SUFFIX) $(OBJDIR)fork_app$(EXE_SUFFIX)
	$(PIN) -xyzzy -enable_rpc_authentication -- $(OBJDIR)fork_app$(EXE_SUFFIX)

# This test verifies that multiple RPC plugins can be loaded. Each plugin logs a message when unloaded.
multiple_json_rpc_plugins.test: $(OBJDIR)inscount0$(PINTOOL_SUFFIX) $(HELLO_APP) $(OBJDIR)$(DLL_PREFIX)simple_plugin$(DLL_SUFFIX)
	# Run the multiple plugins test
	$(PIN) -rpc_plugin simple_plugin_1.$(TARGET_OS).json -rpc_plugin simple_plugin_2.$(TARGET_OS).json -rpc_plugin simple_plugin_3.$(TARGET_OS).json \
		-t $(OBJDIR)inscount0$(PINTOOL_SUFFIX) -- $(HELLO_APP) > $(OBJDIR)multiple_plugins_test_tool.log 2>&1
	# Check results of multiple plugins test
	$(QGREP) "simple plugin 1 is unloaded!" $(OBJDIR)multiple_plugins_test_tool.log
	$(QGREP) "simple plugin 2 is unloaded!" $(OBJDIR)multiple_plugins_test_tool.log
	$(QGREP) "simple plugin 3 is unloaded!" $(OBJDIR)multiple_plugins_test_tool.log
	$(RM) $(OBJDIR)multiple_plugins_test_tool.log

# This test verifies that the user can not override the PIN's configuration file to load RPC plugins.
# This ignores the errors from PIN as sometimes when the config file is illegal PIN exits with injection error.
override_pin_json_config.test: $(OBJDIR)inscount0$(PINTOOL_SUFFIX) $(HELLO_APP) $(OBJDIR)$(DLL_PREFIX)simple_plugin$(DLL_SUFFIX)
	# Run the override pin config test
	- $(PIN) -rpc_plugin simple_plugin_override_pin.$(TARGET_OS).json \
		-t $(OBJDIR)inscount0$(PINTOOL_SUFFIX) -- $(HELLO_APP) > $(OBJDIR)override_pin_config_json.out 2>&1
	# Check results of override pin config test
	$(QGREP) "Illegal config file" $(OBJDIR)override_pin_config_json.out
	$(RM) -f $(OBJDIR)override_pin_config_json.out


        <argsstring>)(IPindPlugin *self, t_rpc_id rpcId, t_arg_count argCount, t_rpc_arg *rpcArgs, t_rpc_ret *retRpcArg)</argsstring>
        <name>do_rpc</name>
        <briefdescription>
<para>Execute the RPC request. Store result in the specified <emphasis>retRpcArg</emphasis>. </para>
        </briefdescription>
        <detaileddescription>
<para>This method is called by pind to actually process an RPC request. This method must be set and may not be NULL.</para>
<para><parameterlist kind="param"><parameteritem>
<parameternamelist>
<parametername direction="in">self</parametername>
</parameternamelist>
<parameterdescription>
<para>A pointer to the plugin </para>
</parameterdescription>
</parameteritem>
<parameteritem>
<parameternamelist>
<parametername direction="in">rpcId</parametername>
</parameternamelist>
<parameterdescription>
<para>RPC request ID </para>
</parameterdescription>
</parameteritem>
<parameteritem>
<parameternamelist>
<parametername direction="in">argCount</parametername>
</parameternamelist>
<parameterdescription>
<para>Number of RPC arguments </para>
</parameterdescription>
</parameteritem>
<parameteritem>
<parameternamelist>
<parametername direction="in">rpcArgs</parametername>
</parameternamelist>
<parameterdescription>
<para>Array of RPC arguments </para>
</parameterdescription>
</parameteritem>
<parameteritem>
<parameternamelist>
<parametername direction="out">retRpcArg</parametername>
</parameternamelist>
<parameterdescription>
<para>Pointer to RPC return value arg. Will be filled with RPC execution result. </para>
</parameterdescription>
</parameteritem>
</parameterlist>
</para>
        </detaileddescription>
